    "paths": {
        "/restaurant/menu/categories": {
            "get": {
                "tags": [
                    "Restaurant"
                ],
                "summary": "List food categories",
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "dataPayload": {
                                            "properties": {
                                                "data": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {}
                ]
            }
        },
        "/restaurant/menu/menu": {
            "get": {
                "tags": [
                    "Restaurant"
                ],
                "summary": "List all food items",
                "parameters": [
                    {
                        "name": "category_id",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "dataPayload": {
                                            "properties": {
                                                "data": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {}
                ]
            }
        },
        "/restaurant/menu/{id}": {
            "get": {
                "tags": [
                    "Restaurant"
                ],
                "summary": "Get specific food item details",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "404": {
                        "description": "Not Found"
                    }
                },
                "security": [
                    {}
                ]
            }
        },
        "/restaurant/menu/search": {
            "get": {
                "tags": [
                    "Restaurant"
                ],
                "summary": "Filter menu items by name",
                "parameters": [
                    {
                        "name": "query",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                },
                "security": [
                    {}
                ]
            }
        },
        "/restaurant/menu/offers": {
            "get": {
                "tags": [
                    "Restaurant"
                ],
                "summary": "Fetch promotional banners/offers",
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                },
                "security": [
                    {}
                ]
            }
        },
        "/restaurant/orders/create": {
            "post": {
                "tags": [
                    "Orders"
                ],
                "summary": "Submit a new order",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "phone_number": {
                                        "type": "string",
                                        "example": "+254..."
                                    },
                                    "delivery_address": {
                                        "type": "string",
                                        "example": "123 Street"
                                    },
                                    "payment_method": {
                                        "type": "string",
                                        "example": "cash"
                                    },
                                    "notes": {
                                        "type": "string",
                                        "example": "Extra spicy"
                                    },
                                    "items": {
                                        "type": "array",
                                        "items": {
                                            "properties": {
                                                "menu_id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "quantity": {
                                                    "type": "integer",
                                                    "example": 2
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Order created"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/restaurant/orders/history": {
            "get": {
                "tags": [
                    "Orders"
                ],
                "summary": "View order history",
                "responses": {
                    "200": {
                        "description": "Order history list"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/restaurant/orders/{id}": {
            "get": {
                "tags": [
                    "Orders"
                ],
                "summary": "Get order status and details",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Order details"
                    },
                    "404": {
                        "description": "Order not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    }
}