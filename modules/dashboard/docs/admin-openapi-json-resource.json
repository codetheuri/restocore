        },
        {
            "url": "https://endpoints.afya365.com/v1",
            "description": "API Production Server"
        }
    ],
    "paths": {
        "/about": {
            "get": {
                "tags": [
                    "ADMIN"
                ],
                "summary": "Module Info. ",
                "responses": {
                    "200": {
                        "description": "success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/About"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {}
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "About": {
                "properties": {
                    "id": {
                        "title": "Module ID",
                        "type": "string",
                        "example": "ADMIN"
                    },
                    "name": {
                        "title": "Module Name",
                        "type": "string",
                        "example": "ADMIN Module"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "security": [
        {
            "bearerAuth": []
        }
    ],
    "tags": [
        {
            "name": "ADMIN",
            "description": "Endpoints for the ADMIN module"
        }
    ]
}